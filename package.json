{
  "name": "siyuan-yemind",
  "version": "0.8.1",
  "private": true,
  "description": "A SiYuan mind-map plugin built around simple-mind-map.",
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && node scripts/copy-build.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "test:watch": "vitest"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "parchment": "^3.0.0",
    "quill": "^2.0.3",
    "quill-delta": "^5.1.0",
    "simple-mind-map": "0.14.0-fix.3",
    "siyuan": "^1.1.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.7"
  }
}
