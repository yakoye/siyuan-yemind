{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2022",
      "DOM"
    ],
    "baseUrl": ".",
    "paths": {
      "siyuan": [
        "src/types/siyuan-shim.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts"
  ]
}
