{
  "project": "siyuan-yemind",
  "profile": "resource-excluded-update",
  "requiresExistingLocalAssets": true,
  "doNotDeleteExcludedPaths": true,
  "exclude": [
    "assets/clipart/**",
    "assets/icons/marker-sprite.png",
    "assets/layout-thumbnails/**/*.svg",
    "assets/layout-thumbnails/layout-thumbnails-contact-sheet.png",
    "yemind-icon-32.png",
    "yemind-icon-64.png",
    "yemind-icon-128.png"
  ],
  "includeExamples": [
    "src/**",
    "scripts/**",
    "docs/**",
    "AGENTS.md",
    "package.json",
    "README.md",
    "tests/**"
  ],
  "packageNotice": "This ZIP omits fixed local assets and must be merged into an existing installation; its filename does not use an -overlay suffix."
}
